# Optional local overrides for build-time constants.
# Defaults are read from wrangler.jsonc "vars".
# Only create this file if you need to override locally without editing wrangler.jsonc.
# In CI/CD, set these as environment variables directly.
#
# API_URL=http://localhost:8000
# API_PREFIX=api/v1
# MOCK_AUTH=true
# API_BASE_URL=https://api.yourdomain.com  # overrides API_URL entirely
